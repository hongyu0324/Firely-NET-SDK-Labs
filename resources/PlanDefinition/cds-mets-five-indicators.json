{
  "resourceType": "PlanDefinition",
  "id": "cds-mets-five-indicators",
  "meta": {
    "profile": [
      "http://hl7.org/fhir/StructureDefinition/cdshooks-plan-definition"
    ]
  },
  "url": "https://www.tmhtc.net/PlanDefinition/cds-mets-five-indicators",
  "version": "1.0.0",
  "name": "CDSMetabolicSyndromeFiveIndicators",
  "title": "CDS Hooks – Metabolic Syndrome (Five Indicators)",
  "status": "active",

  "extension": [
    {
      "url": "http://hl7.org/fhir/StructureDefinition/cqf-cdsHooksEndpoint",
      "valueUri": "https://localhost:8080/fhir/cds-services/metabolic-syndrome"
    }
  ],

  "type": {
    "coding": [
      {
        "system": "http://terminology.hl7.org/CodeSystem/plan-definition-type",
        "code": "eca-rule"
      }
    ]
  },

  "description": "CDS Hooks PlanDefinition for detecting all five metabolic syndrome indicators and generating recommendations.",

  "library": [
    "https://www.tmhtc.net/Library/MetabolicSyndromeLogic"
  ],

  "action": [
    {
      "title": "Evaluate Metabolic Syndrome Indicators",
      "trigger": [
        {
          "type": "named-event",
          "name": "patient-view"
        }
      ],

      "action": [
        {
          "title": "Waist Circumference Abnormal",
          "condition": [
            {
              "kind": "applicability",
              "expression": {
                "language": "text/cql-identifier",
                "expression": "Is_Abnormal_Waist"
              }
            }
          ],
          "type": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/action-type",
                "code": "create"
              }
            ]
          },
          "definitionCanonical": "https://www.tmhtc.net/ActivityDefinition/mets-waist-recommendation"
        },
        {
          "title": "Blood Pressure Abnormal",
          "condition": [
            {
              "kind": "applicability",
              "expression": {
                "language": "text/cql-identifier",
                "expression": "Is_Abnormal_BP"
              }
            }
          ],
          "type": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/action-type",
                "code": "create"
              }
            ]
          },
          "definitionCanonical": "https://www.tmhtc.net/ActivityDefinition/mets-bp-recommendation"
        },
        {
          "title": "Fasting Glucose Abnormal",
          "condition": [
            {
              "kind": "applicability",
              "expression": {
                "language": "text/cql-identifier",
                "expression": "Is_Abnormal_Glucose"
              }
            }
          ],
          "type": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/action-type",
                "code": "create"
              }
            ]
          },
          "definitionCanonical": "https://www.tmhtc.net/ActivityDefinition/mets-glucose-recommendation"
        },
        {
          "title": "Triglycerides Abnormal",
          "condition": [
            {
              "kind": "applicability",
              "expression": {
                "language": "text/cql-identifier",
                "expression": "Is_Abnormal_TG"
              }
            }
          ],
          "type": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/action-type",
                "code": "create"
              }
            ]
          },
          "definitionCanonical": "https://www.tmhtc.net/ActivityDefinition/mets-tg-recommendation"
        },
        {
          "title": "HDL Abnormal",
          "condition": [
            {
              "kind": "applicability",
              "expression": {
                "language": "text/cql-identifier",
                "expression": "Is_Abnormal_HDL"
              }
            }
          ],
          "type": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/action-type",
                "code": "create"
              }
            ]
          },
          "definitionCanonical": "https://www.tmhtc.net/ActivityDefinition/mets-hdl-recommendation"
        }
      ]
    }
  ]
}
