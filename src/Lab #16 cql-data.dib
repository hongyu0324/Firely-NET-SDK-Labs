#!csharp

/// <summary>
/// This code reads CQL library files in JSON format from a specified directory, deserializes them into FHIR Library resources, and prints their URLs.
/// </summary>

var libraryFiles = System.IO.Directory.GetFiles(@"C:\Hongyu\Data\cql\pas\大腸直腸癌", "*.json");
foreach(var library in libraryFiles)
{
    // read each library file
    Console.WriteLine($"Reading library file: {library}");
    var libraryContent = System.IO.File.ReadAllText(library);
    
    // parse the library content as JSON
    var fhirDeserializer = new FhirJsonDeserializer();
    var fhirLibrary = fhirDeserializer.Deserialize<Library>(libraryContent);
    fhirLibrary.Url = "https://nhicore.nhi.gov.tw/cql/Library/" + fhirLibrary.Id;
    fhirLibrary.Name = fhirLibrary.Id;
    Console.WriteLine($"Library {library} has {fhirLibrary.Url}");
    FhirClient client = new FhirClient("http://localhost:8080/fhir");
    var result = await client.UpdateAsync<Library>(fhirLibrary);
    Console.WriteLine($"Uploaded Library {library} with ID: {result.Id}");
}

#!csharp

// Load csv from the specified file name and parse it into a list of tuples
// Some CSV fields contain "," so CsvHelper is used to parse correctly.
var csvFilePath = @"C:\Users\hongy\Downloads\臺灣健保預檢規則 (PAS Library) 元數據匯總表 - Table 1.csv";

// id,type,name,topic,jurisdiction,useContext,relatedArtifact,source
List<dynamic> records;

using (var reader = new StreamReader(csvFilePath))
using (var csv = new CsvHelper.CsvReader(reader, System.Globalization.CultureInfo.InvariantCulture))
{
    records = csv.GetRecords<dynamic>().ToList();
}

// Load Library resources from the FHIR server and print their URLs
FhirClient client = new FhirClient("http://localhost:8080/fhir");
var libraries = await client.SearchAsync<Library>() as Bundle;
foreach (var library in libraries.Entry)
{
    if (library.Resource is Library lib)
    {
        // print records topic with the same id as the library
        var record = records.FirstOrDefault(r => r.id == lib.Id);
        if (record != null)
        {
            lib.Type = new CodeableConcept
            {
                Coding = new List<Coding>
                {
                    new Coding
                    {
                        System = "http://terminology.hl7.org/CodeSystem/library-type",
                        Code = record.type?.ToString()
                    }
                }
            };
            lib.Topic = new List<CodeableConcept> { new CodeableConcept { Text = record.topic } };
            lib.Jurisdiction = new List<CodeableConcept> { new CodeableConcept { Text = record.jurisdiction } };
            lib.UseContext = new List<UsageContext>
            {
                new UsageContext
                {
                    Code = new Coding
                    {
                        Code = "workflow",
                        System = "http://terminology.hl7.org/CodeSystem/usage-context-type"
                    },
                    Value = new CodeableConcept
                    {
                        Text = record.useContext
                    }
                }
            };
            var result = await client.UpdateAsync<Library>(lib);
        }
    }
}

