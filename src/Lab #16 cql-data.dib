#!csharp

// using $everything operation to get all resources related to a patient
// https://www.hl7.org/fhir/operation-patient-everything.html

string patientId = "0322400R12267295200000000000000"; // replace with actual patient ID
FhirClient client = new FhirClient("http://localhost:8080/fhir");
var operationResult = await client.OperationAsync(
    new Uri($"http://localhost:8080/fhir/Patient/{patientId}"),
    "everything",
    parameters: null,
    useGet: true);

var applyResult = operationResult as Bundle
    ?? throw new InvalidOperationException("Patient/$everything did not return a Bundle.");

// display the resources in the bundle
foreach (var entry in applyResult.Entry)
{    
    Console.WriteLine($"Resource Type: {entry.Resource.TypeName}, ID: {entry.Resource.Id}");
}

#!csharp

/// <summary>
/// This code reads CQL library files in JSON format from a specified directory, deserializes them into FHIR Library resources, and prints their URLs.
/// </summary>

var questionnaireFiles = System.IO.Directory.GetFiles(@"C:\Hongyu\Data\公衛表單", "*.json");
foreach(var questionnaire in questionnaireFiles)
{
    // read each questionnaire file
    Console.WriteLine($"Reading questionnaire file: {questionnaire}");
    var questionnaireContent = System.IO.File.ReadAllText(questionnaire);

    //replace "_" with "-" in the content to match FHIR naming conventions
    questionnaireContent = questionnaireContent.Replace("_", "-"); 
    
    // parse the library content as JSON
    var fhirDeserializer = new FhirJsonDeserializer();
    var fhirQuestionnaire = fhirDeserializer.Deserialize<Questionnaire>(questionnaireContent);
    Console.WriteLine($"Questionnaire {questionnaire} has {fhirQuestionnaire.Url}");
    FhirClient client = new FhirClient("http://localhost:8080/fhir");
    var result = await client.UpdateAsync<Questionnaire>(fhirQuestionnaire);
    Console.WriteLine($"Uploaded Questionnaire {questionnaire} with ID: {result.Id}");
}

