重組檔案結構

#!csharp

var patientDirectory = @"C:\Hongyu\Data\cql\02-口腔黏膜\OralMucosaScreening\patient-case03";

var resourceFiles = System.IO.Directory.GetFiles(patientDirectory, "*.json");

foreach(var resourceFile in resourceFiles)
{
    if (resourceFile.Split("\\").ToList().Last().StartsWith("bundle"))
    {
        continue;
    }
    string typeName = resourceFile.Split("\\").ToList().Last().Split("_").ToList()[0];
    string directory = patientDirectory + "\\" + typeName;
    if (!Directory.Exists(directory))
    {
        Directory.CreateDirectory(directory);
    }

    // move the file to the directory
    string fileName = resourceFile.Split("\\").ToList().Last();
    string newFilePath = directory + "\\" + fileName;
    System.IO.File.Move(resourceFile, newFilePath);
}

#!markdown

上傳FHIR Data From Directory

#!csharp

async Task<string> UploadResourceToFhirServer(string resourceFile,FhirClient client = null)
{
    var resourceContent = System.IO.File.ReadAllText(resourceFile);
    var fhirDeserializer = new FhirJsonDeserializer();
    var fhirResource = fhirDeserializer.Deserialize<Resource>(resourceContent);

    if (client == null)
    {
        client = new FhirClient("http://localhost:8080/fhir");
    }
    var result = await client.UpdateAsync(fhirResource);
    
    return result.Id;
}
// input\tests\MetabolicSyndromeLogic
var patientDirectory = @"C:\Hongyu\Project\公衛表單\input\tests\Mammography\mammoA01";
List<string> resourceTypes = new List<string> { 
    "Organization",
    "Location",
    "Practitioner",
    "Patient",
    "Coverage",
    "RelatedPerson",
    "Condition",
    "Encounter",
    "Specimen",
    "Observation",  
    "MedicationRequest",
    "ServiceRequest",
    "DiagnosticReport",
    "CarePlan",
    "MedicationStatement",
    "Immunization",
    "Procedure",
    "ImagingStudy",
    "Device"
};

FhirClient client = new FhirClient("http://localhost:8080/fhir");
foreach(var type in resourceTypes)
{
    // if the directory does not exist, skip
    if (!Directory.Exists(patientDirectory + $@"\{type}"))    {
        Console.WriteLine($"Directory {patientDirectory + $@"\{type}"} does not exist, skipping resource type {type}");
        continue;
    }
    var files = System.IO.Directory.GetFiles(patientDirectory + $@"\{type}", "*.json");

    foreach(var file in files)
    {
        try{
            string resultId = await UploadResourceToFhirServer(file, client);
            Console.WriteLine($"Uploaded Resource {file} with ID: {resultId}");
        }
        catch(Exception ex)
        {
            Console.WriteLine($"Error uploading resource {file}: {ex.Message}");
        }
    }
}

#!csharp

string medicationCodeFile = @"C:\Hongyu\Data\ig\pas2\code\1140728_癌症用藥給付規定所列基因檢測項目.csv";
var medicationCodes = System.IO.File.ReadAllLines(medicationCodeFile);

// ignore the first two lines (header)
medicationCodes = medicationCodes.Skip(2).ToArray();

string currentDisease = "";
string currentMedication = "";
string currentCode = "";
string currentChinese = "";
string currentEnglish = "";
string currentGene = "";

foreach(var medicationCode in medicationCodes)
{
    var codeParts = medicationCode.Split(',');
    if(codeParts.Length < 8) continue; // skip if the line doesn't have enough parts

    if(!string.IsNullOrEmpty(codeParts[0].Trim())) currentDisease = codeParts[0].Trim();
    if(!string.IsNullOrEmpty(codeParts[1].Trim())) currentMedication = codeParts[1].Trim();
    if(!string.IsNullOrEmpty(codeParts[2].Trim())) currentCode = codeParts[2].Trim();
    if(!string.IsNullOrEmpty(codeParts[3].Trim())) currentChinese = codeParts[3].Trim();
    if(!string.IsNullOrEmpty(codeParts[4].Trim())) currentEnglish = codeParts[4].Trim();
    if(!string.IsNullOrEmpty(codeParts[5].Trim())) currentGene = codeParts[5].Trim();


    Console.WriteLine($"Disease: {currentDisease}, Medication: {currentMedication}, Code: {currentCode}, Chinese: {currentChinese}, English: {currentEnglish}, Gene: {currentGene}");
}

